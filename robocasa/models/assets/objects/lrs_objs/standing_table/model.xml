<mujoco model="coffee_shop_standing_table">
  <asset>
  <texture file="/Users/hyunw3/robotics/robotics-safety/benchmark/robosuite/robosuite/models/assets/textures/ceramic.png" name="tex-coffee_shop_standing_table" type="2d" />
  <material name="coffee_shop_standing_table" reflectance="0.5" texrepeat="1 1" texture="tex-coffee_shop_standing_table" texuniform="false" />
  <mesh file="visual/model_normalized_0.obj" name="model_normalized_0_vis" scale="0.6 0.6 1.2" /><mesh file="visual/model_normalized_1.obj" name="model_normalized_1_vis" scale="0.6 0.6 1.2" /><mesh file="visual/model_normalized_2.obj" name="model_normalized_2_vis" scale="0.6 0.6 1.2" /><mesh file="visual/model_normalized_3.obj" name="model_normalized_3_vis" scale="0.6 0.6 1.2" /><texture type="2d" name="material_1" file="visual/material_1.png" /><texture type="2d" name="material_3" file="visual/material_3.png" /><material name="material_0" specular="0.4000000000000001" shininess="0.001" rgba="0.00000000 0.00000000 0.00000000 1.0" /><material name="material_1" texture="material_1" specular="0.4000000000000001" shininess="0.001" /><material name="material_2" specular="0.4000000000000001" shininess="0.001" rgba="0.40000000 0.40000000 0.40000000 1.0" /><material name="material_3" texture="material_3" specular="0.4000000000000001" shininess="0.001" /></asset>
  <worldbody>
    <body>

      <body name="object">
        <!-- Visual: keep original meshes (no collision). -->
        <geom type="mesh" mesh="model_normalized_0_vis" conaffinity="0" contype="0" group="1" material="material_3" />
        <geom type="mesh" mesh="model_normalized_1_vis" conaffinity="0" contype="0" group="1" material="material_2" />
        <geom type="mesh" mesh="model_normalized_2_vis" conaffinity="0" contype="0" group="1" material="material_1" />
        <geom type="mesh" mesh="model_normalized_3_vis" conaffinity="0" contype="0" group="1" material="material_0" />
        <!-- Collision: a single cylinder approximating the full table envelope.
             The original convex-decomposed mesh had ~33 pieces, some of which
             protruded above the table top and would intersect a wine bottle's
             punt at spawn, launching it sideways on the first physics step.
             A single cylinder gives a clean flat top for objects to rest on.
             Dimensions chosen from the original sites:
               horizontal_radius_site x = 0.508 -> world radius 0.508 * 0.6 ≈ 0.305
               top_site z = +0.370, bottom_site z = -0.373 -> half-height 0.371
                 (mesh z-scale 1.2 is applied to mesh, not sites; we use the
                  site spacing so the cylinder matches the visible mesh extent.) -->
        <geom name="standing_table_collision" type="cylinder" size="0.305 0.45"
              pos="0 0 0.0" group="0" rgba="0.8 0.8 0.8 0.0"
              solimp="0.998 0.998 0.001" solref="0.001 1"
              density="100" friction="0.95 0.3 0.1" />
        <site rgba="0 0 0 1" size="0.005" pos="-0.304545 -0.304545 -0.447181" name="ext_p0" />
        <site rgba="1 0 0 1" size="0.005" pos="0.304545 -0.304545 -0.447181" name="ext_px" />
        <site rgba="0 1 0 1" size="0.005" pos="-0.304545 0.304545 -0.447181" name="ext_py" />
        <site rgba="0 0 1 1" size="0.005" pos="-0.304545 -0.304545 0.443728" name="ext_pz" />

        <site rgba="0.5 0.5 0.5 1" size="0.01" pos="0 0 0" name="int_p0"/>
        <site rgba="1 1 0 1" size="0.01" pos="0 0 0" name="int_px"/>
        <site rgba="0 1 1 1" size="0.01" pos="0 0 0" name="int_py"/>
        <site rgba="1 0 1 1" size="0.01" pos="0 0 0" name="int_pz"/>
        <site rgba="0 0 0 0" size="0.005" pos="0.0 -1.2499999924031613e-09 -0.37265077527138857" name="bottom_site" />
        <site rgba="0 0 0 0" size="0.005" pos="0.0 -1.2499999924031613e-09 0.36977347997103593" name="top_site" />
        <site rgba="0 0 0 0" size="0.005" pos="0.5075757663825758 0.5075757651325759 -0.0014386476501763168" name="horizontal_radius_site" />
      </body>
    </body>
  </worldbody>
</mujoco>
